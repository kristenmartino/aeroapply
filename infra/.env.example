# Copy to .env (gitignored). Dev defaults match infra/docker-compose.yml.
APP_ENV=dev

# --- Database (dev = local Docker; prod = Railway private network URL) ---
DATABASE_URL=postgresql://aeroapply:aeroapply@localhost:5432/aeroapply

# --- Credential vault ---
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AEROAPPLY_FERNET_KEY=

# --- Model providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=            # used for embeddings (text-embedding-3-small)
DEEPSEEK_API_KEY=          # optional, strict-reasoner critic
OLLAMA_HOST=http://localhost:11434   # optional local Llama for sourcing/classification

# --- Embeddings (dimension MUST match scripts/bootstrap.sql vector(N)) ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Email-event service ---
MAILGUN_SIGNING_KEY=       # inbound webhook signature verification
AGENT_EMAIL=you.agents@example.com
PRIMARY_EMAIL=you@example.com
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=imap.example.com
IMAP_USER=
IMAP_PASSWORD=

# --- Autonomy gates (secure-by-default) ---
DEFAULT_MODE=review        # review | auto
WIP_LIMIT=5
SCHEDULER_CYCLE_MINUTES=180
MIN_ATS_SCORE=0.90
MIN_AGENT_CONFIDENCE=0.95

# --- Per-node model overrides (optional; override the registry defaults) ---
# MODEL__TAILOR_GENERATOR=anthropic:claude-opus-4-8
# MODEL__TAILOR_CRITIC=anthropic:claude-sonnet-4-6
# MODEL__SOURCING_PARSER=ollama:llama3.1
